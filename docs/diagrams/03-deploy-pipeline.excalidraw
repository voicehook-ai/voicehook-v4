    },
    {
      "type": "text", "id": "rule_idempotent",
      "x": 80, "y": 700, "width": 540, "height": 80,
      "text": "Idempotent contract:\n  terraform apply twice  ==  same result\n  deploy.sh on existing box  ==  re-renders + reloads, no drift\nNo SSH hot-fixes. Box state is a pure function of TF + git commit.",
      "originalText": "Idempotent contract:\n  terraform apply twice  ==  same result\n  deploy.sh on existing box  ==  re-renders + reloads, no drift\nNo SSH hot-fixes. Box state is a pure function of TF + git commit.",
      "fontSize": 12, "fontFamily": 3,
      "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#5b21b6", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100, "angle": 0,
