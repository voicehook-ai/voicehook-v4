    {
      "type": "text", "id": "rule_secrets",
      "x": 80, "y": 600, "width": 540, "height": 60,
      "text": "SECRETS NEVER LEAVE LEFT SIDE OF BOUNDARY EXCEPT VIA user_data.\nNot in git, not in env file on laptop, not in any log line\n  (p2ai never prints, terraform marks sensitive=true).",
      "originalText": "SECRETS NEVER LEAVE LEFT SIDE OF BOUNDARY EXCEPT VIA user_data.\nNot in git, not in env file on laptop, not in any log line\n  (p2ai never prints, terraform marks sensitive=true).",
      "fontSize": 12, "fontFamily": 3,
      "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#b91c1c", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100, "angle": 0,
