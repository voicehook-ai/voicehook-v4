    },
    {
      "type": "text", "id": "rule_ci",
      "x": 80, "y": 810, "width": 540, "height": 50,
      "text": "CI gate (ci.yml):  ruff + pytest run on PR and on push.\nFailing CI blocks merge to main; main is the only branch the operator deploys.",
      "originalText": "CI gate (ci.yml):  ruff + pytest run on PR and on push.\nFailing CI blocks merge to main; main is the only branch the operator deploys.",
