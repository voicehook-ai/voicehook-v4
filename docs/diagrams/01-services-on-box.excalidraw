      ],
      "link": null, "locked": false, "roundness": {"type": 3}
    },
    {
      "type": "text", "id": "svc_agent_title",
      "x": 776, "y": 236, "width": 288, "height": 28,
      "text": "voicehook-agent.service",
      "originalText": "voicehook-agent.service",
      "fontSize": 18, "fontFamily": 3,
      "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#5b21b6", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 100062, "version": 1, "versionNonce": 100063,
      "isDeleted": false, "groupIds": [], "boundElements": null,
      "link": null, "locked": false, "containerId": null, "lineHeight": 1.25
    },
    {
      "type": "text", "id": "svc_agent_body",
      "x": 776, "y": 274, "width": 288, "height": 290,
      "text": "python -m agent\n(/opt/voicehook/.venv)\n\nthread 1  uvicorn FastAPI\n  127.0.0.1:7400\n  POST /api/token\n  GET  /api/healthz\n\nthread 2 (blocking, main)\n  livekit-agents worker\n  registers agent_name=\"voice-ai\"\n  connects wss://livekit:7880\n\nspawns RelayAgent per job:\n  on_user_turn_completed\n    -> StopResponse (relay only)",
      "originalText": "python -m agent\n(/opt/voicehook/.venv)\n\nthread 1  uvicorn FastAPI\n  127.0.0.1:7400\n  POST /api/token\n  GET  /api/healthz\n\nthread 2 (blocking, main)\n  livekit-agents worker\n  registers agent_name=\"voice-ai\"\n  connects wss://livekit:7880\n\nspawns RelayAgent per job:\n  on_user_turn_completed\n    -> StopResponse (relay only)",
      "fontSize": 12, "fontFamily": 3,
      "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#374151", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 100064, "version": 1, "versionNonce": 100065,
      "isDeleted": false, "groupIds": [], "boundElements": null,
      "link": null, "locked": false, "containerId": null, "lineHeight": 1.4
    },
