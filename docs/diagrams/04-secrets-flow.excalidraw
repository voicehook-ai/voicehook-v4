    {
      "type": "text", "id": "stage2_code_t",
      "x": 432, "y": 298, "width": 200, "height": 226,
      "text": "deploy-staging.sh\n\np2ai run \\\n  -e HCLOUD_TOKEN \\\n  -e INVITE_SECRET \\\n  -e LIVEKIT_API_KEY \\\n  -e LIVEKIT_API_SECRET \\\n  -e DEEPGRAM_API_KEY \\\n  -e GOOGLE_API_KEY \\\n  -e GCP_SA_JSON \\\n  -- bash -c '\n  export TF_VAR_hcloud_token=\\\n    $HCLOUD_TOKEN\n  ...\n  terraform apply'\n\n(no --print, no echo)",
      "originalText": "deploy-staging.sh\n\np2ai run \\\n  -e HCLOUD_TOKEN \\\n  -e INVITE_SECRET \\\n  -e LIVEKIT_API_KEY \\\n  -e LIVEKIT_API_SECRET \\\n  -e DEEPGRAM_API_KEY \\\n  -e GOOGLE_API_KEY \\\n  -e GCP_SA_JSON \\\n  -- bash -c '\n  export TF_VAR_hcloud_token=\\\n    $HCLOUD_TOKEN\n  ...\n  terraform apply'\n\n(no --print, no echo)",
      "fontSize": 10, "fontFamily": 3,
      "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#22c55e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 400026, "version": 1, "versionNonce": 400027,
      "isDeleted": false, "groupIds": [], "boundElements": null,
      "link": null, "locked": false, "containerId": null, "lineHeight": 1.4
