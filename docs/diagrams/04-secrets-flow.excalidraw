    {
      "type": "text", "id": "stage3_code_t",
      "x": 762, "y": 298, "width": 200, "height": 234,
      "text": "variable \"invite_secret\" {\n  type      = string\n  sensitive = true\n}\n\ndata \"cloudinit_config\"\n  \"user_data\" {\n  part {\n    content = templatefile(\n      \"cloud-init.yaml.tmpl\",\n      {\n        invite_secret =\n          var.invite_secret,\n        lk_secret =\n          var.lk_secret,\n        ...\n      }\n    )\n  }\n}",
      "originalText": "variable \"invite_secret\" {\n  type      = string\n  sensitive = true\n}\n\ndata \"cloudinit_config\"\n  \"user_data\" {\n  part {\n    content = templatefile(\n      \"cloud-init.yaml.tmpl\",\n      {\n        invite_secret =\n          var.invite_secret,\n        lk_secret =\n          var.lk_secret,\n        ...\n      }\n    )\n  }\n}",
      "fontSize": 10, "fontFamily": 3,
      "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#22c55e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
