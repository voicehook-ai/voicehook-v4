    {
      "type": "text", "id": "stage1_kp_b",
      "x": 92, "y": 288, "width": 220, "height": 320,
      "text": "~/private.kdbx\n(offline, encrypted)\n\nsource of truth for:\n\n  HCLOUD_TOKEN\n  INVITE_SECRET\n  LIVEKIT_API_KEY\n  LIVEKIT_API_SECRET\n  DEEPGRAM_API_KEY\n  GOOGLE_API_KEY\n  GCP_SA_JSON  (attached)\n\nunlocked only by\nTouch-ID via p2ai\n\n--  never synced  --\n--  never in git --",
      "originalText": "~/private.kdbx\n(offline, encrypted)\n\nsource of truth for:\n\n  HCLOUD_TOKEN\n  INVITE_SECRET\n  LIVEKIT_API_KEY\n  LIVEKIT_API_SECRET\n  DEEPGRAM_API_KEY\n  GOOGLE_API_KEY\n  GCP_SA_JSON  (attached)\n\nunlocked only by\nTouch-ID via p2ai\n\n--  never synced  --\n--  never in git --",
