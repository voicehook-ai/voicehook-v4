    {
      "type": "text", "id": "stoptresp_t",
      "x": 602, "y": 254, "width": 296, "height": 76,
      "text": "RelayAgent.on_user_turn_completed:\n    raise StopResponse()\n\n   NEVER auto-generates speech.\n   Only speaks when senior tells it to.",
