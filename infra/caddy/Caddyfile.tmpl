{
  email ops@voicehook.ai
}

__SITE_MAIN__ {
  encode zstd gzip
  log {
    output file /var/log/caddy/access.log
    format console
  }
  handle /api/* {
    reverse_proxy 127.0.0.1:7400
  }
  handle {
    root * /var/www/voicehook
    try_files {path} /voice.html
    file_server
  }
}

__SITE_RTC__ {
  reverse_proxy 127.0.0.1:7880
}
